# Oracle
ORACLE_PASSWORD=change_sys_oracle_password
APP_DB_USERNAME=CAFE_APP
APP_DB_PASSWORD=change_cafe_app_password

# Default admin created by backend if missing
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change_admin_password
DEFAULT_ADMIN_EMAIL=admin@phungloc.local

# Password reset mail
MAIL_ENABLED=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_FROM=your_email@gmail.com
PASSWORD_RESET_CODE_MINUTES=10
PASSWORD_RESET_MAX_ATTEMPTS=5
PASSWORD_RESET_RETURN_CODE=false

# payOS
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
PAYOS_RETURN_URL=https://your-ngrok-or-domain/payos/return
PAYOS_CANCEL_URL=https://your-ngrok-or-domain/payos/cancel

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=coffee-chain/products
